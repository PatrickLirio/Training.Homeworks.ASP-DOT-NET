# .gitignore for a .NET 8 + Angular project

# ========================
# .NET / Visual Studio
# ========================

# Build outputs
[Bb]in/
[Oo]bj/
*/bin/
*/obj/

# Publish output
**/publish/

# Visual Studio workspace & user files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.sln.iml
*.Rider/

# VS Code
.vscode/
*.code-workspace

# NuGet / packages
packages/
*.nupkg
project.lock.json
project.fragment.lock.json
.nuget/

# ASP.NET Core / secrets and local settings
secrets.json
appsettings.Development.json
appsettings.*.local

# ========================
# Angular / Node
# ========================

# Dependencies
node_modules/

# Angular build output
dist/
build/
.tmp/
out-tsc/

# Angular cache
.angular/cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment files (optional: keep example instead)
src/environments/environment*.ts

# Compiled JS / maps
*.js.map

# Coverage
coverage/

# ========================
# Testing
# ========================
TestResults/
*.trx
*.coverage
*.coveragexml

# ========================
# Logs and databases
# ========================
*.log
*.sqlite
*.db
*.mdf
*.ldf
*.db-journal

# ========================
# IDE / tool caches
# ========================
_ReSharper*/
*.ReSharper
*.DotSettings.user

# ========================
# OS generated files
# ========================
.DS_Store
Thumbs.db

# ========================
# Temp files
# ========================
*.tmp
*.temp

# ========================
# Local environment files
# ========================
.env
.env.local
.env.*.local
